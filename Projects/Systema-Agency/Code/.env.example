# ----------------------------
# Core runtime (required)
# ----------------------------
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-a-strong-password
VITE_APP_ID=systema-agency

# ----------------------------
# Client options (optional)
# ----------------------------
# Cross-site cookies mode:
# - empty/false => SameSite=Lax (recommended default)
# - true        => SameSite=None on HTTPS requests only
COOKIE_CROSS_SITE=

# If set, unauth redirects use this URL. Default fallback is "/".
VITE_LOGIN_URL=

# Optional local password gate on the client.
VITE_APP_PASSWORD=

# Optional analytics (used in client/index.html).
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional frontend runtime error sink (POST JSON payload).
VITE_ERROR_LOG_ENDPOINT=

# ----------------------------
# Platform/runtime provided vars
# ----------------------------
# NODE_ENV and PORT are normally provided by the runtime.
# Add them locally only if needed for debugging.
# NODE_ENV=development
# PORT=3000
